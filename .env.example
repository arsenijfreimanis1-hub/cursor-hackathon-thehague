# Database (matches docker compose --profile postgres)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/rekentafel

# Public URL when hosted (Caddy + cloudflared). Used for QR codes and guest links.
# Local dev: leave unset or use http://localhost:5173
PUBLIC_BASE_URL=

# API
API_PORT=3000
API_BASE_URL=http://localhost:3000/v1
GUEST_WEB_URL=http://localhost:5173
STAFF_WEB_URL=http://localhost:5174/staff

# Auth (dev only)
JWT_SECRET=dev-change-me-in-production
DEV_VENUE_ID=aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa
DEV_STAFF_ID=bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb

# Mollie (test key from https://www.mollie.com/dashboard/developers/api-keys)
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOLLIE_WEBHOOK_URL=http://localhost:3000/v1/webhooks/mollie

# Redis (optional — realtime scaling)
REDIS_URL=redis://127.0.0.1:6379
