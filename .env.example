# William Agent — copy to .env and fill in values
#
# Required for cloud reasoning + codegen:
CURSOR_API_KEY=cursor_...

# Optional tuning
JARVIS_OLLAMA_MODEL=llama3.1:8b
JARVIS_BRIEFING_HOUR=8
JARVIS_LEARNING_REPORT_INTERVAL_HOURS=4
JARVIS_MEMORY_COMPRESS_INTERVAL_HOURS=6
JARVIS_TIMEZONE=Europe/Amsterdam
JARVIS_MUSIC_PROVIDER=spotify
JARVIS_INTENT_LLM_ENABLED=true

# Optional local offline voice stack
# Run ./scripts/setup-local-voice.sh, then reinstall helper.
WILLIAM_VOICE_BACKEND=apple_legacy
WILLIAM_OPENWAKEWORD_COMMAND=
WILLIAM_OPENWAKEWORD_MODEL=
WILLIAM_OPENWAKEWORD_THRESHOLD=0.62
WILLIAM_WHISPER_COMMAND=
WILLIAM_WHISPER_MODEL=

# Optional Notion learning export
JARVIS_NOTION_API_KEY=
JARVIS_NOTION_PARENT_PAGE_ID=

# Always-on screen observer (Notion relay + self-improvement)
JARVIS_SCREEN_WATCH_ENABLED=true
JARVIS_SCREEN_CAPTURE_INTERVAL_SECONDS=10
JARVIS_SCREEN_SUMMARY_WINDOW_SECONDS=60
JARVIS_SCREEN_SCREENSHOT_RETENTION_MINUTES=30
JARVIS_SCREEN_OBSERVER_INTERVAL_SECONDS=60
JARVIS_SCREEN_SEMANTIC_ANCHOR_THRESHOLD=0.5
JARVIS_SCREENPIPE_BRIDGE_ENABLED=false
JARVIS_SCREENPIPE_BASE_URL=http://127.0.0.1:3030
JARVIS_POPUP_HANDLER_ENABLED=true
JARVIS_POPUP_MAX_ATTEMPTS=3
JARVIS_CURSOR_TRACE_ENABLED=true

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_BUCKET=jarvis-backups
JARVIS_PUBLIC_HOSTNAME=

# Get CURSOR_API_KEY: https://cursor.com/dashboard/integrations
