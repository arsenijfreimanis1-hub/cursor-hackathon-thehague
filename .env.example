# Copy to .env — NEVER commit real secrets

# ─── William / Jarvis agent ─────────────────────────────────────────────────

JARVIS_HOST=127.0.0.1
JARVIS_PORT=8787

# Storage (Mac mini internal — run ./scripts/migrate-storage.sh once)
# JARVIS_DATA_DIR=/Users/willy/Library/Application Support/Jarvis/data
# JARVIS_STATE_ROOT=/Users/willy/Library/Application Support/Jarvis
# JARVIS_LOGS_DIR=/Users/willy/Library/Logs/Jarvis
# JARVIS_WORKSPACE_DIR=/Users/willy/jarvis-core

# LLM / integrations (optional)
CURSOR_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=

# Public webhooks (Cloudflare tunnel, etc.)
PUBLIC_WEBHOOK_URL=

# Optional Redis (docker compose --profile redis)
REDIS_URL=redis://127.0.0.1:6379

# Vigil / remote (optional)
VIGIL_API_KEY=
