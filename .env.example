# Copy to .env (Rekentafel) or .env.local (hackathon integrations) — NEVER commit real secrets

# ─── Rekentafel (bill-splitting MVP) ───────────────────────────────────────

# Database (matches docker compose --profile postgres)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/rekentafel

# Public URL when hosted (set automatically by ./scripts/rekentafel-poc.sh)
PUBLIC_BASE_URL=

# Mac mini LAN IP on venue Wi‑Fi — run: ./scripts/print-network-urls.sh
VITE_LAN_HOST=

# Staff/guest Vite apps — set when building waiter iOS app on MacBook
# VITE_API_BASE_URL=https://your-public-host.trycloudflare.com/v1
# VITE_BASE_PATH=/staff/

API_PORT=3000
API_BASE_URL=http://localhost:3000/v1
GUEST_WEB_URL=http://localhost:5173
STAFF_WEB_URL=http://localhost:5174/staff

JWT_SECRET=dev-change-me-in-production
DEV_VENUE_ID=aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa
DEV_STAFF_ID=bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb

# Mollie TEST mode — https://www.mollie.com/dashboard/developers/api-keys
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOLLIE_WEBHOOK_URL=http://localhost:3000/v1/webhooks/mollie

REDIS_URL=redis://127.0.0.1:6379

# ─── Hackathon integrations (Competitor Watchdog) ────────────────────────────

APIFY_TOKEN=
ELEVENLABS_API_KEY=
N8N_BASE_URL=https://YOUR_INSTANCE.app.n8n.cloud
N8N_WEBHOOK_BASE_URL=
N8N_API_KEY=
FLUXZERO_API_KEY=
APP_BASE_URL=http://localhost:3000
PUBLIC_WEBHOOK_URL=
