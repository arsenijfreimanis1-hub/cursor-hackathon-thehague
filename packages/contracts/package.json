{
  "name": "@rekentafel/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./openapi.yaml": "./openapi.yaml",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "validate:openapi": "swagger-cli validate openapi.yaml",
    "generate:types": "openapi-typescript openapi.yaml -o src/generated/api.d.ts"
  },
  "dependencies": {
    "@rekentafel/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@apidevtools/swagger-cli": "^4.0.4",
    "@rekentafel/config": "workspace:*",
    "eslint": "^9.29.0",
    "openapi-typescript": "^7.8.0",
    "typescript": "^5.8.3"
  }
}
