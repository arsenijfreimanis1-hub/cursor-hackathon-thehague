{
  "id": "jarvis-bridge",
  "name": "Jarvis Bridge",
  "description": "Routes inbound messages to William Agent (JarvisCore) instead of OpenClaw's built-in brain.",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "hooks": ["inbound_claim"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "jarvisUrl": {
        "type": "string"
      },
      "channels": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  },
  "uiHints": {
    "jarvisUrl": {
      "label": "JarvisCore URL",
      "help": "Base URL for JarvisCore (default: http://127.0.0.1:8787)"
    },
    "channels": {
      "label": "Channels",
      "help": "Channels to bridge (default: whatsapp). Empty = all."
    }
  }
}
