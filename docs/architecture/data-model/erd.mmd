%% PART 9 — Entity Relationship Diagram
%% Product: TabSettle / Rekentafel (NL hospitality split-pay)
%% Render: Mermaid erDiagram (GitHub, VS Code, mermaid.live)
%% Registry: dining_session_id, payment_session_id, participant_id, bill_version

erDiagram
    restaurants ||--o{ venues : owns
    restaurants ||--o| mollie_connections : connects
    restaurants ||--o{ staff_members : employs
    restaurants ||--o{ menu_categories : catalogs

    venues ||--o{ tables : contains
    venues ||--o{ menu_categories : scopes
    venues ||--o{ dining_sessions : hosts

    tables ||--|| table_qr_codes : resolves_via
    tables ||--o| dining_sessions : current_session
    tables ||--o{ service_signals : receives

    users ||--o{ guest_devices : links_optional
    users ||--o| rewards_accounts : earns
    users ||--o{ staff_members : logs_in_as
    users ||--o{ participants : links_optional

    guest_devices ||--o{ participants : joins_as
    guest_devices ||--o{ service_signals : sends

    dining_sessions ||--o| payment_sessions : activates
    dining_sessions ||--|| bills : drafts
    dining_sessions ||--o{ orders : pos_future
    dining_sessions }o--|| tables : at
    dining_sessions }o--|| venues : at
    dining_sessions }o--|| restaurants : tenant

    staff_members ||--o{ dining_sessions : opens
    staff_members ||--o{ payment_sessions : activates
    staff_members ||--o{ staff_devices : registers
    staff_members ||--o{ audit_log_entries : acts
    staff_members ||--o{ payment_refunds : initiates

    payment_sessions ||--|| bills : snapshots
    payment_sessions ||--o{ payment_session_tokens : issues
    payment_sessions ||--o{ participants : roster
    payment_sessions ||--o{ checkout_intents : checkouts
    payment_sessions ||--o{ payment_intents : attempts
    payment_sessions ||--o{ payments : confirms

    participants ||--o{ allocations : claims
    participants ||--o{ custom_pledges : pledges
    participants ||--o| checkout_intents : active_checkout
    participants ||--o{ payment_intents : pays
    participants ||--o{ payments : paid

    bills ||--o{ bill_lines : lines
    bills ||--o{ allocations : allocates
    bills ||--o{ custom_pledges : custom_splits
    bills ||--o{ bill_state_events : transitions

    bill_lines ||--o{ allocatable_units : derives
    bill_lines }o--o| menu_items : references
    bill_lines }o--o| order_items : pos_future

    allocatable_units ||--o{ allocations : claimed_by

    checkout_intents ||--|| tips : tip
    checkout_intents ||--o| payment_intents : creates
    checkout_intents }o--|| participants : for

    payment_intents ||--o| payments : confirms
    payment_intents }o--|| mollie_connections : via_restaurant

    payments ||--o{ payment_refunds : refunds
    payments ||--o| tips : settles_tip
    payments ||--o{ disputes : disputed
    payments ||--o{ rewards_ledger_entries : accrual

    rewards_accounts ||--o{ rewards_ledger_entries : ledger
    rewards_accounts ||--o{ redemptions : redeems_post_mvp

    partner_merchants ||--o{ redemptions : offers_post_mvp

    orders ||--o{ order_items : lines_post_mvp

    webhook_events }o--o| payment_intents : resolves
    webhook_events }o--o| payments : updates

    restaurants ||--o{ audit_log_entries : scoped
    restaurants ||--o{ disputes : scoped
    restaurants ||--o{ incidents : scoped

    menu_categories ||--o{ menu_items : items

    restaurants {
        uuid id PK
        varchar slug UK
        restaurant_status status
        varchar mollie_org_id
        boolean payments_enabled
        jsonb settings_json
    }

    venues {
        uuid id PK
        uuid restaurant_id FK
        varchar name
        varchar timezone
        boolean is_active
    }

    tables {
        uuid id PK
        uuid venue_id FK
        varchar table_code
        uuid current_dining_session_id FK
    }

    table_qr_codes {
        uuid id PK
        uuid table_id FK UK
        varchar public_slug UK
        text qr_payload_url
        int version
    }

    users {
        uuid id PK
        citext email UK
        user_status status
        timestamptz deleted_at
    }

    guest_devices {
        uuid id PK
        uuid user_id FK
        char fingerprint_hash
        char ip_hash
    }

    staff_members {
        uuid id PK
        uuid restaurant_id FK
        uuid user_id FK
        staff_role role
        boolean is_active
    }

    staff_devices {
        uuid id PK
        uuid staff_member_id FK
        timestamptz last_active_at
    }

    dining_sessions {
        uuid id PK
        uuid table_id FK
        dining_session_state state
        uuid active_payment_session_id FK
        timestamptz opened_at
        timestamptz closed_at
    }

    payment_sessions {
        uuid id PK
        uuid dining_session_id FK
        uuid bill_id FK
        payment_session_state state
        char join_pin
        boolean claims_frozen
    }

    payment_session_tokens {
        uuid id PK
        uuid payment_session_id FK
        char token_hash UK
        token_state state
        timestamptz expires_at
    }

    participants {
        uuid id PK
        uuid payment_session_id FK
        uuid guest_device_id FK
        uuid user_id FK
        participant_state state
        varchar display_name
    }

    bills {
        uuid id PK
        uuid payment_session_id FK UK
        int bill_version
        bill_settlement_state settlement_state
        int bill_grand_total_cents
        int confirmed_paid_cents
        int remaining_cents
    }

    bill_lines {
        uuid id PK
        uuid bill_id FK
        bill_line_kind line_kind
        int line_total_inc_vat_cents
        int vat_rate_bps
        boolean splittable
    }

    allocatable_units {
        uuid id PK
        uuid bill_line_id FK
        smallint unit_index
        int unit_value_cents
        smallint max_shares
    }

    allocations {
        uuid id PK
        uuid bill_id FK
        uuid allocatable_unit_id FK
        uuid participant_id FK
        split_mode split_mode
        int allocated_amount_cents
        allocation_state state
        int version
    }

    custom_pledges {
        uuid id PK
        uuid bill_id FK
        uuid participant_id FK
        int amount_cents
    }

    checkout_intents {
        uuid id PK
        uuid participant_id FK
        int checkout_total_cents
        varchar idempotency_key UK
        int bill_version
        jsonb allocation_snapshot_json
    }

    payment_intents {
        uuid id PK
        uuid checkout_intent_id FK
        varchar mollie_payment_id UK
        payment_intent_status status
        int amount_cents
        varchar idempotency_key UK
    }

    payments {
        uuid id PK
        uuid payment_intent_id FK UK
        varchar mollie_payment_id UK
        int amount_cents
        int tip_cents
        settlement_status settlement_status
    }

    tips {
        uuid id PK
        uuid checkout_intent_id FK UK
        uuid payment_id FK
        int tip_cents
        tip_destination destination
    }

    payment_refunds {
        uuid id PK
        uuid payment_id FK
        varchar mollie_refund_id UK
        int amount_cents
    }

    mollie_connections {
        uuid id PK
        uuid restaurant_id FK UK
        bytea refresh_token_enc
        varchar onboarding_status
    }

    rewards_accounts {
        uuid id PK
        uuid user_id FK UK
        int points_balance
    }

    rewards_ledger_entries {
        uuid id PK
        uuid rewards_account_id FK
        rewards_entry_type entry_type
        int points_delta
        uuid payment_id FK
    }

    partner_merchants {
        uuid id PK
        varchar slug UK
        varchar status
    }

    redemptions {
        uuid id PK
        uuid rewards_account_id FK
        uuid partner_merchant_id FK
        redemption_status status
    }

    service_signals {
        uuid id PK
        uuid table_id FK
        uuid guest_device_id FK
        service_signal_type signal_type
        signal_status status
    }

    orders {
        uuid id PK
        uuid dining_session_id FK
        order_source source
    }

    order_items {
        uuid id PK
        uuid order_id FK
        varchar external_line_id
    }

    menu_categories {
        uuid id PK
        uuid venue_id FK
        varchar name
    }

    menu_items {
        uuid id PK
        uuid category_id FK
        int price_display_cents
    }

    audit_log_entries {
        uuid id PK
        uuid restaurant_id FK
        timestamptz occurred_at
        varchar action
        uuid resource_id
        jsonb payload_json
    }

    webhook_events {
        uuid id PK
        webhook_source source
        varchar idempotency_key UK
        webhook_processing_status processing_status
        jsonb payload_json
    }

    disputes {
        uuid id PK
        uuid payment_id FK
        dispute_type dispute_type
        dispute_status status
        int amount_cents
    }

    incidents {
        uuid id PK
        incident_severity severity
        uuid restaurant_id FK
        incident_status status
    }
