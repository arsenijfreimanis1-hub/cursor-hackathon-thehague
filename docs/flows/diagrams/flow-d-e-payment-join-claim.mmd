%% Flow D & E — Payment join and multi-user claiming
flowchart LR
    subgraph Join["Flow D — Join"]
        QR([Scan QR or open link]) --> HAS_TOKEN{Token or PIN present?}
        HAS_TOKEN -->|no| GATE[Show PAYMENT_NOT_OPEN + PIN field]
        HAS_TOKEN -->|yes| VALIDATE{Validate token}
        GATE --> PIN[Enter 6-digit PIN]
        PIN --> VALIDATE
        VALIDATE -->|expired| EXP[JOIN_TOKEN_EXPIRED]
        VALIDATE -->|invalid| INV[JOIN_TOKEN_INVALID]
        VALIDATE -->|ok| JOIN[Create participant_id]
        JOIN --> LOBBY[Payment lobby + remaining balance]
    end

    subgraph Claim["Flow E — Claim items"]
        LOBBY --> LIST[Bill item list with avatars]
        LIST --> CLAIM_ACTION[Select qty → Assign to me]
        CLAIM_ACTION --> LOCK{bill locked?}
        LOCK -->|yes| BL[BILL_LOCKED refresh]
        LOCK -->|no| TXN[Transactional claim write]
        TXN -->|conflict| CC[CLAIM_CONFLICT refresh]
        TXN -->|ok| EMIT[claim.created + ledger recalc]
        EMIT --> MY[Update My share summary]
        MY --> LIST
    end

    style EXP fill:#f96
    style INV fill:#f96
    style CC fill:#fa6
    style EMIT fill:#6f6
